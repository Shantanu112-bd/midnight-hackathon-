# ────────────────────────────────────────────────────────────────────
# ProofWork — Environment Configuration
# ────────────────────────────────────────────────────────────────────

# Server
PORT=3001

# ── Mode Toggles ───────────────────────────────────────────────────
# MOCK_MODE=true  → Blockchain calls return mock success responses
# MOCK_AI=true    → AI extraction returns hardcoded test data
MOCK_MODE=true
MOCK_AI=true

# ── Midnight Network (used when MOCK_MODE=false) ──────────────────
MIDNIGHT_NODE_URL=http://localhost:9944
MIDNIGHT_INDEXER_URL=http://localhost:8088
MIDNIGHT_INDEXER_WS=ws://localhost:8088/ws
PROOF_SERVER_URL=http://localhost:6300

# Wallet seed (64-char hex — auto-generated if empty)
WALLET_SEED=

# Network ID (leave empty for devnet default)
NETWORK_ID=

# ── Anthropic API (used when MOCK_AI=false) ────────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
